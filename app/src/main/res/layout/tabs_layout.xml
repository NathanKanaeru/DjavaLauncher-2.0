<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tab_window"
        android:layout_width="@dimen/_380sdp"
        android:layout_height="@dimen/_220sdp"
        android:layout_gravity="center"
        android:background="@drawable/tab_background"
        android:clickable="true"
        android:padding="@dimen/_5sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/tab_close"
            android:layout_width="@dimen/_18sdp"
            android:layout_height="@dimen/_18sdp"
            android:clickable="true"
            android:src="@drawable/chat_hide_icon"
            android:rotation="90"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tab_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_bold"
            android:paddingStart="@dimen/_3sdp"
            android:paddingTop="@dimen/_3sdp"
            android:text="PLAYERS"
            android:textColor="@color/white"
            android:textSize="@dimen/_10sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tab_total_players"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:fontFamily="@font/roboto_medium"
            android:text="0"
            android:textColor="#959494"
            android:textSize="@dimen/_7sdp"
            app:layout_constraintBottom_toBottomOf="@+id/tab_title"
            app:layout_constraintStart_toEndOf="@+id/tab_title"
            app:layout_constraintTop_toTopOf="@+id/tab_title" />

        <LinearLayout
            android:id="@+id/tab_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_3sdp"
            android:layout_marginEnd="@dimen/_3sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/tab_title">

            <TextView
                android:layout_width="@dimen/_12sdp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="ID"
                android:textColor="#959494"
                android:textSize="@dimen/_7sdp" />

            <TextView
                android:layout_width="@dimen/_40sdp"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="Name"
                android:textColor="#959494"
                android:textSize="@dimen/_7sdp" />

            <TextView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:fontFamily="@font/roboto_medium"
                android:includeFontPadding="false"
                android:paddingStart="@dimen/_10sdp"
                android:text="Score"
                android:textColor="#959494"
                android:textSize="@dimen/_7sdp" />

            <TextView
                android:layout_width="@dimen/_5sdp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_weight="2"
                android:fontFamily="@font/roboto_medium"
                android:includeFontPadding="false"
                android:text="Ping"
                android:textColor="#959494"
                android:textSize="@dimen/_7sdp" />
        </LinearLayout>

        <View
            android:id="@+id/tab_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/_2sdp"
            android:background="#70333333"
            app:layout_constraintTop_toBottomOf="@+id/tab_header_row" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tab_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/_3sdp"
            android:layout_marginEnd="@dimen/_3sdp"
            android:layout_marginTop="@dimen/_3sdp"
            android:layout_marginBottom="@dimen/_3sdp"
            android:scrollbarStyle="insideInset"
            android:scrollbarThumbVertical="@drawable/ic_dialog_scrollbar_thumb"
            android:scrollbarTrackVertical="@drawable/ic_dialog_scrollbar_track"
            android:scrollbars="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tab_divider" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
