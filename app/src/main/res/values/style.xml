<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="tab_layout_title" parent="@android:style/TextAppearance.Widget.TabWidget">
        <item name="android:fontFamily">@font/montserrat_bold</item>
    </style>

    <style name="SettingsSectionHeader" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:textColor">@color/md_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="DjavaBottomNavActiveIndicator">
        <item name="android:color">@color/bottom_nav_indicator</item>
        <item name="shapeAppearance">@style/DjavaBottomNavActiveIndicatorShape</item>
        <item name="android:height">48dp</item>
    </style>

    <style name="DjavaBottomNavActiveIndicatorShape" parent="ShapeAppearance.Material3.Corner.Full" />
</resources>
